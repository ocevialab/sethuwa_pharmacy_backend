# QA: https://sethsuwa-phama.ocevialab.com
# Copy to /etc/nginx/sites-available/ and symlink sites-enabled; then certbot --nginx.
#
# Assumes:
#   - SPA static files: /var/www/sethsuwa-phama-qa/html
#   - Kestrel (systemd): http://127.0.0.1:5180

server {
    listen 80;
    listen [::]:80;
    server_name sethsuwa-phama.ocevialab.com;

    root /var/www/sethsuwa-phama-qa/html;
    index index.html;

    location /api/ {
        proxy_pass         http://127.0.0.1:5180;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Connection "";
        proxy_buffering    off;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }

    access_log /var/log/nginx/sethsuwa-phama-qa.access.log;
    error_log  /var/log/nginx/sethsuwa-phama-qa.error.log;
}
